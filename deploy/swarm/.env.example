# Nome lógico da stack no Swarm
STACK_NAME=astracalls

# Imagem que será construída/publicada e depois usada pela stack
IMAGE_REPO=ghcr.io/artbras/abrio-astracalls-wacalls
IMAGE_TAG=latest

# Domínio público atendido pelo Traefik
PUBLIC_HOST=w.arthurbrasileiro.com.br

# Rede overlay já usada pelo Traefik/Portainer nesta VPS
TRAEFIK_NETWORK=hermesaquiles

# Entrada/certresolver do Traefik
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERTRESOLVER=letsencryptresolver

# Nome do router/service do Traefik para o proxy HTTP do AstraCalls
TRAEFIK_ROUTER_NAME=wacalls

# API key do AstraCalls (obrigatória em produção)
WACALLS_API_KEY=troque-por-uma-chave-forte

# IP público anunciado ao navegador para NAT 1:1 / ICE-TCP
# Use "auto" para autodetecção ou informe o IP fixo da VPS
WACALLS_PUBLIC_IP=auto

# Porta de mídia do WebRTC/ICE-TCP (publicada em UDP e TCP host mode)
WACALLS_UDP_PORT=50000

# Porta HTTP local do processo wacalls dentro do host
WACALLS_HTTP_PORT=8080

# Limite de chamadas simultâneas por sessão
WACALLS_MAX_CALLS=4

# Prefixo dos bancos por sessão
WACALLS_PG_NAMESPACE=wacalls

# Habilita logs verbosos do wacalls (estrutura atual da VPS)
WACALLS_DEBUG=true

# Postgres da stack
POSTGRES_DB=postgres
POSTGRES_USER=wacalls
POSTGRES_PASSWORD=troque-por-uma-senha-forte
POSTGRES_PORT=5433

# Opcional: força deploy em um nó específico pelo hostname do Docker
# Exemplo: manager-01
DEPLOY_NODE_HOSTNAME=